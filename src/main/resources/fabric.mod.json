{
  "schemaVersion": 1,
  "id": "fps",
  "version": "${version}",

  "name": "FPS (Fabric)",
  "description": "Adds a simple real-time FPS counter to the game.",
  "authors": [
    ""
  ],
  "contact": {
    "homepage": "https://fabricmc.net/",
    "sources": "https://github.com/FabricMC/fabric-example-mod"
  },

  "license": "CC0-1.0",
  "icon": "assets/fps/icon.png",

  "environment": "client",
  "entrypoints": {
    "client": [
      "com.example.fps.FpsModClient"
    ]
  },
  "mixins": [
    "fps.mixins.json"
  ],

  "depends": {
    "fabricloader": ">=0.16.9",
    "fabric-api": ">=0.107.0+1.21.1",
    "minecraft": "~1.21.1",
    "java": ">=21"
  },
  "suggests": {
    "another-mod": "*"
  }
}